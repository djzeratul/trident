---
import AlbumCard from './AlbumCard.astro';
import type { Artist } from '../data/site';

interface Props {
  artist: Artist;
}

const { artist } = Astro.props;
---
<section id={`discography-${artist.slug}`} class="discography">
  <div class="discography-header">
    <div>
      <div class="section-label">Discography</div>
      <h2>Current releases</h2>
    </div>

    <p>
      TRIDENT treats releases like a proper catalog layer: coherent visual language, clean navigation,
      and a place for future expansion without redesigning the whole site.
    </p>
  </div>

  <div class="wave-divider"></div>

  <div class="grid">
    {artist.albums.map((album) => <AlbumCard album={album} />)}
  </div>
</section>

<style>
  .discography {
    margin-top: 2.25rem;
    padding: 1.25rem 0 3rem;
  }

  .discography-header {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(280px, 420px);
    gap: 1rem 2rem;
    align-items: end;
  }

  .discography-header h2 {
    margin: 0.7rem 0 0;
    font-size: clamp(1.8rem, 1.55rem + 1vw, 2.6rem);
    line-height: 1;
    letter-spacing: -0.04em;
  }

  .discography-header p {
    margin: 0;
    color: var(--muted);
    line-height: 1.7;
  }

  .grid {
    margin-top: 1.5rem;
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 1.1rem;
  }

  @media (max-width: 860px) {
    .discography-header,
    .grid {
      grid-template-columns: 1fr;
    }
  }
</style>
