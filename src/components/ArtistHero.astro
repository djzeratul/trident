---
import type { Artist } from '../data/site';

interface Props {
  artist: Artist;
}

const { artist } = Astro.props;
---
<section class="hero glass-panel">
  <div class="hero-copy">
    <div class="section-label">TRIDENT / Artist View</div>
    <h1>{artist.name}</h1>
    <p class="tagline">{artist.tagline}</p>
    <p class="bio">{artist.bio}</p>

    <div class="hero-actions">
      <a class="button-link" href={`#discography-${artist.slug}`}>View discography</a>
      <a class="button-link secondary" href="/">Back to artists</a>
    </div>
  </div>

  <div class="hero-visual">
    <div class="hero-ring"></div>
    <img src={artist.heroImage} alt={`${artist.name} hero artwork`} loading="eager" />
  </div>
</section>

<style>
  .hero {
    position: relative;
    display: grid;
    grid-template-columns: minmax(0, 1.2fr) minmax(320px, 0.8fr);
    gap: 2rem;
    padding: clamp(1.2rem, 1rem + 2vw, 2rem);
    border-radius: var(--radius-xl);
    overflow: hidden;
  }

  .hero::after {
    content: '';
    position: absolute;
    inset: auto 0 0 0;
    height: 180px;
    background: linear-gradient(180deg, transparent, rgba(255, 123, 97, 0.06));
    pointer-events: none;
  }

  .hero-copy {
    position: relative;
    z-index: 1;
    display: flex;
    flex-direction: column;
    justify-content: center;
    min-width: 0;
  }

  h1 {
    margin: 0.7rem 0 0;
    font-size: clamp(2.4rem, 2rem + 2vw, 4.5rem);
    line-height: 0.94;
    letter-spacing: -0.04em;
  }

  .tagline {
    margin: 1rem 0 0;
    max-width: 36rem;
    color: var(--muted-strong);
    font-size: clamp(1.02rem, 0.98rem + 0.3vw, 1.2rem);
    line-height: 1.45;
  }

  .bio {
    margin: 1rem 0 0;
    max-width: 42rem;
    color: var(--muted);
    line-height: 1.72;
  }

  .hero-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.85rem;
    margin-top: 1.5rem;
  }

  .hero-visual {
    position: relative;
    min-height: 360px;
    display: grid;
    place-items: center;
  }

  .hero-visual img {
    width: min(100%, 470px);
    aspect-ratio: 1;
    border-radius: 999px;
    object-fit: cover;
    box-shadow: 0 20px 50px rgba(0, 0, 0, 0.42);
    border: 1px solid rgba(255, 255, 255, 0.06);
  }

  .hero-ring {
    position: absolute;
    width: min(92%, 420px);
    aspect-ratio: 1;
    border-radius: 999px;
    border: 1px solid rgba(105, 210, 255, 0.18);
    box-shadow: 0 0 0 20px rgba(105, 210, 255, 0.03), 0 0 120px rgba(105, 210, 255, 0.06);
  }

  @media (max-width: 960px) {
    .hero {
      grid-template-columns: 1fr;
    }

    .hero-visual {
      order: -1;
      min-height: 280px;
    }

    .hero-visual img {
      width: min(100%, 360px);
    }
  }
</style>
