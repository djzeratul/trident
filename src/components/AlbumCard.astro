---
import type { Album } from '../data/site';

interface Props {
  album: Album;
}

const { album } = Astro.props;
---
<article class="album-card glass-panel" style={`--album-accent: ${album.accent};`}>
  <a class="cover-wrap" href={album.shareUrl} target="_blank" rel="noreferrer">
    <img src={album.coverSrc} alt={`${album.title} cover art`} loading="lazy" />
  </a>

  <div class="album-meta">
    <div class="album-topline">
      <span>{album.year}</span>
      <span class="dot"></span>
      <span>Release</span>
    </div>

    <h2>
      <a href={album.shareUrl} target="_blank" rel="noreferrer">{album.title}</a>
    </h2>

    <p>{album.summary}</p>

    <div class="album-actions">
      <a class="button-link" href={album.shareUrl} target="_blank" rel="noreferrer">Open album</a>
    </div>
  </div>
</article>

<style>
  .album-card {
    position: relative;
    display: grid;
    gap: 1.15rem;
    padding: 1rem;
    border-radius: var(--radius-lg);
    overflow: hidden;
  }

  .album-card::before {
    content: '';
    position: absolute;
    inset: -35% auto auto -10%;
    width: 240px;
    height: 240px;
    border-radius: 999px;
    background: radial-gradient(circle, color-mix(in srgb, var(--album-accent), transparent 78%), transparent 70%);
    pointer-events: none;
  }

  .cover-wrap {
    display: block;
    position: relative;
    overflow: hidden;
    border-radius: 999px;
    aspect-ratio: 1;
    border: 1px solid rgba(255, 255, 255, 0.06);
    width: min(100%, 320px);
    justify-self: center;
    transition: transform 180ms ease, box-shadow 180ms ease, border-color 180ms ease;
    box-shadow: 0 12px 28px rgba(0, 0, 0, 0.38);
  }

  .cover-wrap:hover {
    transform: translateY(-2px) scale(1.01);
    border-color: color-mix(in srgb, var(--album-accent), white 35%);
    box-shadow: 0 20px 38px rgba(0, 0, 0, 0.5);
  }

  .cover-wrap img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .album-meta {
    position: relative;
    z-index: 1;
  }

  .album-topline {
    display: inline-flex;
    align-items: center;
    gap: 0.55rem;
    color: var(--muted);
    font-size: 0.82rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .dot {
    width: 4px;
    height: 4px;
    border-radius: 999px;
    background: color-mix(in srgb, var(--album-accent), white 30%);
  }

  h2 {
    margin: 0.75rem 0 0;
    font-size: clamp(1.45rem, 1.3rem + 0.4vw, 1.75rem);
    line-height: 1.04;
    letter-spacing: -0.03em;
  }

  h2 a:hover {
    color: color-mix(in srgb, var(--album-accent), white 25%);
  }

  p {
    margin: 0.8rem 0 0;
    color: var(--muted);
    line-height: 1.65;
  }

  .album-actions {
    margin-top: 1rem;
  }
</style>
