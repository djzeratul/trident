---
interface Props {
  title: string;
  description?: string;
}

const {
  title,
  description = 'TRIDENT — Transformative Rendering Interface for Discography, Experience & Navigation Toolkit.'
} = Astro.props;
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="icon" href="data:image/svg+xml,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 64 64'%3E%3Cpath fill='%2369d2ff' d='M29 4h6v21l8-8 4 4-12 12v17h9v6H20v-6h9V33L17 21l4-4 8 8z'/%3E%3C/svg%3E" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <slot />
  </body>
</html>

<style is:global>
  :root {
    --bg: #070a11;
    --panel: rgba(14, 19, 33, 0.86);
    --panel-strong: rgba(16, 22, 36, 0.96);
    --line: rgba(105, 210, 255, 0.12);
    --line-strong: rgba(105, 210, 255, 0.28);
    --text: #eef4ff;
    --muted: #a2afc9;
    --muted-strong: #c3cbe0;
    --glow: 0 0 0 1px rgba(105, 210, 255, 0.12), 0 12px 40px rgba(0, 0, 0, 0.42);
    --page-max: 1200px;
    --radius-xl: 28px;
    --radius-lg: 22px;
    --radius-md: 16px;
  }

  * { box-sizing: border-box; }
  html { color-scheme: dark; }
  body {
    margin: 0;
    min-height: 100vh;
    background:
      radial-gradient(circle at top, rgba(105, 210, 255, 0.08), transparent 28%),
      radial-gradient(circle at 85% 12%, rgba(255, 123, 97, 0.10), transparent 20%),
      linear-gradient(180deg, #0a0e16 0%, #070a11 100%);
    color: var(--text);
    font-family: 'Inter', system-ui, sans-serif;
  }

  a { color: inherit; text-decoration: none; }
  img { display: block; max-width: 100%; }

  .page-shell {
    width: min(calc(100% - 2rem), var(--page-max));
    margin: 0 auto;
  }

  .section-label {
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
    font-size: 0.78rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--muted);
  }

  .section-label::before {
    content: '';
    width: 2.5rem;
    height: 1px;
    background: linear-gradient(90deg, rgba(105, 210, 255, 0.85), transparent);
  }

  .wave-divider {
    height: 1px;
    margin: 1.75rem 0 0;
    background:
      linear-gradient(90deg, transparent, rgba(105, 210, 255, 0.3), transparent),
      repeating-linear-gradient(90deg, transparent 0 16px, rgba(105, 210, 255, 0.10) 16px 17px);
  }

  .glass-panel {
    border: 1px solid var(--line);
    background: linear-gradient(180deg, rgba(17, 23, 37, 0.92), rgba(10, 14, 22, 0.88));
    box-shadow: var(--glow);
    backdrop-filter: blur(14px);
  }

  .button-link {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.55rem;
    min-height: 44px;
    padding: 0.78rem 1.1rem;
    border-radius: 999px;
    border: 1px solid rgba(255, 255, 255, 0.08);
    background: linear-gradient(180deg, rgba(105, 210, 255, 0.18), rgba(105, 210, 255, 0.10));
    color: var(--text);
    font-weight: 600;
    letter-spacing: 0.01em;
    transition: transform 160ms ease, border-color 160ms ease, background 160ms ease;
  }

  .button-link:hover {
    transform: translateY(-1px);
    border-color: rgba(105, 210, 255, 0.28);
    background: linear-gradient(180deg, rgba(105, 210, 255, 0.24), rgba(105, 210, 255, 0.14));
  }

  .button-link.secondary {
    background: rgba(255, 255, 255, 0.02);
    color: var(--muted-strong);
  }

  .button-link.secondary:hover {
    background: rgba(255, 255, 255, 0.05);
  }

  @media (max-width: 720px) {
    .page-shell {
      width: min(calc(100% - 1.2rem), var(--page-max));
    }
  }
</style>
